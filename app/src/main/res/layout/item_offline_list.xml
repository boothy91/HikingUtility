<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    app:cardBackgroundColor="#2E2218"
    app:cardCornerRadius="16dp"
    app:cardElevation="4dp"
    app:strokeColor="#5C4033"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical">

        <!-- Map icon -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🗺️"
            android:textSize="28sp"
            android:layout_marginEnd="14dp" />

        <!-- Name and area info -->
        <LinearLayout
            android:orientation="vertical"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content">

            <TextView
                android:id="@+id/tv_map_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Map Name"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="#D4C5A9"
                android:layout_marginBottom="4dp" />

            <TextView
                android:id="@+id/tv_map_area"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Area: 0.0 km²"
                android:textSize="13sp"
                android:textColor="#A89880" />

        </LinearLayout>

        <!-- Delete button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_delete_map"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:text="Delete"
            android:textSize="13sp"
            android:textColor="#CF6679"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            app:strokeColor="#7A3B2E"
            app:cornerRadius="10dp" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
