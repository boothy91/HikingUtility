<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1C1410"
    android:fitsSystemWindows="true"
    android:padding="20dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Page Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="TRACKING"
            android:textColor="#D4C5A9"
            android:textSize="22sp"
            android:textStyle="bold"
            android:letterSpacing="0.15"
            android:layout_marginBottom="20dp" />

        <!-- Stats Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardBackgroundColor="#2E2218"
            app:cardCornerRadius="20dp"
            app:cardElevation="6dp"
            app:strokeColor="#5C4033"
            app:strokeWidth="1dp">

            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="20dp"
                android:columnCount="2"
                android:rowCount="4">

                <!-- Distance Header -->
                <TextView
                    android:layout_row="0"
                    android:layout_column="0"
                    android:layout_gravity="center"
                    android:layout_marginBottom="8dp"
                    android:gravity="center"
                    android:text="DISTANCE"
                    android:textColor="#A89880"
                    android:textSize="12sp"
                    android:letterSpacing="0.12"
                    android:textStyle="bold" />

                <!-- Time Header -->
                <TextView
                    android:layout_row="0"
                    android:layout_column="1"
                    android:layout_gravity="center"
                    android:layout_marginBottom="8dp"
                    android:gravity="center"
                    android:text="TIME"
                    android:textColor="#A89880"
                    android:textSize="12sp"
                    android:letterSpacing="0.12"
                    android:textStyle="bold" />

                <!-- Distance Value -->
                <TextView
                    android:id="@+id/tv_distance"
                    android:layout_row="1"
                    android:layout_column="0"
                    android:layout_gravity="center"
                    android:layout_marginBottom="24dp"
                    android:gravity="center"
                    android:text="0.00 km"
                    android:textColor="#D4C5A9"
                    android:textSize="26sp"
                    android:textStyle="bold" />

                <!-- Duration Value -->
                <TextView
                    android:id="@+id/tv_duration"
                    android:layout_row="1"
                    android:layout_column="1"
                    android:layout_gravity="center"
                    android:layout_marginBottom="24dp"
                    android:gravity="center"
                    android:text="00:00:00"
                    android:textColor="#D4C5A9"
                    android:textSize="26sp"
                    android:textStyle="bold" />

                <!-- Divider line (fake with view) -->

                <!-- Current Pace Header -->
                <TextView
                    android:layout_row="2"
                    android:layout_column="0"
                    android:layout_gravity="center"
                    android:layout_marginBottom="8dp"
                    android:gravity="center"
                    android:text="CURRENT PACE"
                    android:textColor="#A89880"
                    android:textSize="12sp"
                    android:letterSpacing="0.12"
                    android:textStyle="bold" />

                <!-- Avg Pace Header -->
                <TextView
                    android:layout_row="2"
                    android:layout_column="1"
                    android:layout_gravity="center"
                    android:layout_marginBottom="8dp"
                    android:gravity="center"
                    android:text="AVG PACE"
                    android:textColor="#A89880"
                    android:textSize="12sp"
                    android:letterSpacing="0.12"
                    android:textStyle="bold" />

                <!-- Current Pace Value -->
                <TextView
                    android:id="@+id/tv_current_pace"
                    android:layout_row="3"
                    android:layout_column="0"
                    android:layout_gravity="center"
                    android:gravity="center"
                    android:text="--'--&quot;"
                    android:textColor="#8B6914"
                    android:textSize="26sp"
                    android:textStyle="bold" />

                <!-- Avg Pace Value -->
                <TextView
                    android:id="@+id/tv_avg_pace"
                    android:layout_row="3"
                    android:layout_column="1"
                    android:layout_gravity="center"
                    android:gravity="center"
                    android:text="--'--&quot;"
                    android:textColor="#8B6914"
                    android:textSize="26sp"
                    android:textStyle="bold" />

            </GridLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Open Map Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_open_map"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="🗺️  Open Map"
            android:textSize="15sp"
            android:textColor="#D4C5A9"
            android:textStyle="bold"
            android:layout_marginBottom="12dp"
            app:backgroundTint="#5C4033"
            app:cornerRadius="16dp"
            app:rippleColor="#7A5C46" />

        <!-- Start/Stop Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_start_stop"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:text="▶  Start Tracking"
            android:textSize="17sp"
            android:textColor="#D4C5A9"
            android:textStyle="bold"
            android:letterSpacing="0.05"
            app:backgroundTint="#4A7C59"
            app:cornerRadius="16dp"
            app:rippleColor="#6B9E75" />

    </LinearLayout>
</ScrollView>
