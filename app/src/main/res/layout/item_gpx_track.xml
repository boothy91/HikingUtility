<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    app:cardBackgroundColor="#2E2218"
    app:cardCornerRadius="16dp"
    app:cardElevation="4dp"
    app:strokeColor="#5C4033"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Track name -->
        <TextView
            android:id="@+id/tv_track_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Track Name"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#D4C5A9"
            android:layout_marginBottom="12dp" />

        <!-- Actions Row -->
        <LinearLayout
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical">

            <!-- Show on map toggle -->
            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/switch_show_on_map"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Show on Map"
                android:textSize="13sp"
                android:textColor="#A89880"
                app:thumbTint="#8B6914"
                app:trackTint="#5C4033" />

            <!-- Share button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_share_track"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:text="Share"
                android:textSize="13sp"
                android:textColor="#D4C5A9"
                android:layout_marginEnd="8dp"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                app:strokeColor="#5C4033"
                app:cornerRadius="10dp" />

            <!-- Delete button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_delete_track"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:text="Delete"
                android:textSize="13sp"
                android:textColor="#CF6679"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                app:strokeColor="#7A3B2E"
                app:cornerRadius="10dp" />

        </LinearLayout>
    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
