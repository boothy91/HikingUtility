<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#1C1410"
    android:fitsSystemWindows="true"
    android:padding="20dp">

    <!-- Title -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="OFFLINE MAPS"
        android:textColor="#D4C5A9"
        android:textSize="22sp"
        android:textStyle="bold"
        android:letterSpacing="0.15"
        android:layout_marginBottom="6dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Manage your downloaded map regions"
        android:textColor="#A89880"
        android:textSize="14sp"
        android:layout_marginBottom="20dp" />

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#3D2B1A"
        android:layout_marginBottom="12dp" />

    <!-- List -->
    <ListView
        android:id="@+id/offline_list"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:divider="#3D2B1A"
        android:dividerHeight="1dp" />

</LinearLayout>
