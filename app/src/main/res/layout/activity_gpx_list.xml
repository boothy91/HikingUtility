<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#1C1410"
    android:fitsSystemWindows="true"
    android:padding="20dp">

    <!-- Title -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="GPX LIBRARY"
        android:textColor="#D4C5A9"
        android:textSize="22sp"
        android:textStyle="bold"
        android:letterSpacing="0.15"
        android:layout_marginBottom="6dp" />

    <TextView
        android:id="@+id/tv_track_count"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="0 tracks found"
        android:textColor="#A89880"
        android:textSize="14sp"
        android:layout_marginBottom="20dp" />

    <!-- Import Buttons -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_import_gpx"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:text="📂  Import GPX File"
        android:textSize="15sp"
        android:textColor="#D4C5A9"
        android:textStyle="bold"
        android:layout_marginBottom="10dp"
        app:cornerRadius="14dp"
        app:backgroundTint="#4A7C59" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_import_osm"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:text="🌐  Import OSM Trace"
        android:textSize="15sp"
        android:textColor="#D4C5A9"
        android:textStyle="bold"
        android:layout_marginBottom="20dp"
        app:cornerRadius="14dp"
        app:backgroundTint="#5C4033" />

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#3D2B1A"
        android:layout_marginBottom="12dp" />

    <!-- Track List -->
    <ListView
        android:id="@+id/list_gpx_tracks"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:divider="#3D2B1A"
        android:dividerHeight="1dp" />

</LinearLayout>
