<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#2E2218"
    android:padding="24dp">

    <!-- Dialog Title -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="NAME YOUR TRAIL"
        android:textColor="#D4C5A9"
        android:textSize="16sp"
        android:textStyle="bold"
        android:letterSpacing="0.12"
        android:layout_marginBottom="16dp" />

    <!-- Track Name Input -->
    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:hint="Track name"
        app:hintTextColor="#A89880"
        app:boxStrokeColor="#5C4033"
        app:boxBackgroundColor="#1C1410"
        app:boxBackgroundMode="outline"
        app:boxCornerRadiusBottomEnd="12dp"
        app:boxCornerRadiusBottomStart="12dp"
        app:boxCornerRadiusTopEnd="12dp"
        app:boxCornerRadiusTopStart="12dp">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/et_track_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="textCapSentences"
            android:maxLines="1"
            android:imeOptions="actionDone"
            android:textColor="#D4C5A9"
            android:textSize="15sp" />

    </com.google.android.material.textfield.TextInputLayout>

    <!-- Help Text -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardBackgroundColor="#241A10"
        app:cardCornerRadius="12dp"
        app:cardElevation="0dp"
        app:strokeColor="#3D2B1A"
        app:strokeWidth="1dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🏔️  Examples: 'Mountain Trail', 'Beach Walk', 'City Hike'\n\n⚠️  GPS will record your location every few seconds and may use more battery."
            android:textColor="#A89880"
            android:textSize="13sp"
            android:lineSpacingMultiplier="1.4"
            android:padding="14dp" />

    </com.google.android.material.card.MaterialCardView>

</LinearLayout>
